# Variables de entorno requeridas para LogMAR Pro en Vercel
# Copiar este archivo a .env.local para desarrollo local
# En producción, configurar en: Vercel Dashboard → Project → Settings → Environment Variables

# URL completa del Google Apps Script que valida las claves de licencia.
# NUNCA exponer este valor en código fuente ni en el cliente.
# Ejemplo: https://script.google.com/macros/s/TU_SCRIPT_ID/exec
GOOGLE_SCRIPT_URL=https://script.google.com/macros/s/REEMPLAZAR_CON_ID_REAL/exec

# Secreto para firmar los tokens de activación (HMAC-SHA256).
# Usar un string aleatorio de al menos 32 caracteres.
# Generarlo con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
LICENSE_SECRET=REEMPLAZAR_CON_STRING_ALEATORIO_DE_32_CHARS
